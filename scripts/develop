#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Create config dir if not present
if [[ ! -d "${PWD}/config" ]]; then
    mkdir -p "${PWD}/config"
    hass --config "${PWD}/config" --script ensure_config
fi

# Let HA find the integration at <root>/custom_components/btclock
export PYTHONPATH="${PYTHONPATH}:${PWD}/custom_components"

# If BTCLOCK_DEBUGPY=1, start under debugpy for VSCode attach on :5678
if [[ "${BTCLOCK_DEBUGPY:-0}" == "1" ]]; then
    exec python3 -m debugpy --listen 0.0.0.0:5678 --wait-for-client \
        -m homeassistant --config "${PWD}/config" --debug
else
    exec hass --config "${PWD}/config" --debug
fi

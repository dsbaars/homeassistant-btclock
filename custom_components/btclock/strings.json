{
  "config": {
    "flow_title": "BTClock: {name}",
    "step": {
      "user": {
        "description": "Tap the bottom button on the device to display its IP address.",
        "data": {
          "host": "Hostname or IP address"
        }
      },
      "zeroconf_confirm": {
        "title": "Discovered BTClock",
        "description": "Do you want to add the discovered BTClock {name}?"
      },
      "credentials": {
        "description": "This BTClock requires HTTP Basic authentication.",
        "data": {
          "username": "Username",
          "password": "Password"
        }
      },
      "reauth_confirm": {
        "description": "Credentials for the BTClock are no longer valid. Please re-enter them.",
        "data": {
          "username": "Username",
          "password": "Password"
        }
      },
      "reconfigure": {
        "description": "Change the BTClock's hostname or IP address.",
        "data": {
          "host": "Hostname or IP address"
        }
      },
      "update_mode": {
        "title": "How should Home Assistant keep state in sync?",
        "description": "Events (Server-Sent Events) push changes instantly over a persistent connection. Polling asks the device for the latest status at a fixed interval. The scan interval only applies to polling.",
        "data": {
          "update_mode": "Update mode",
          "scan_interval": "Scan interval"
        }
      }
    },
    "error": {
      "cannot_connect": "Unable to connect to the BTClock.",
      "invalid_auth": "Invalid username or password.",
      "unknown": "An unexpected error occurred."
    },
    "abort": {
      "already_configured": "This BTClock is already configured.",
      "cannot_connect": "Unable to connect to the BTClock.",
      "another_device": "The selected address points to a different BTClock.",
      "reauth_successful": "Credentials updated.",
      "reconfigure_successful": "Configuration updated."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Update settings",
        "description": "Events push changes instantly; polling asks the device on a schedule. Scan interval only applies to polling.",
        "data": {
          "update_mode": "Update mode",
          "scan_interval": "Scan interval"
        }
      }
    }
  },
  "selector": {
    "update_mode": {
      "options": {
        "events": "Server-Sent Events (push)",
        "polling": "Polling"
      }
    }
  },
  "entity": {
    "binary_sensor": {
      "price_connected":  { "name": "Price feed" },
      "blocks_connected": { "name": "Blocks feed" },
      "v2_connected":     { "name": "V2 relay" },
      "timer_running":    { "name": "Screen timer" },
      "dnd_active":       { "name": "Do-not-disturb active" }
    },
    "button": {
      "identify":         { "name": "Identify" },
      "restart":          { "name": "Restart" },
      "full_refresh":     { "name": "Full refresh" },
      "screen_next":      { "name": "Next screen" },
      "screen_previous":  { "name": "Previous screen" },
      "frontlight_flash": { "name": "Flash frontlight" }
    },
    "light": {
      "led":        { "name": "LED {index}" },
      "frontlight": { "name": "Frontlight" }
    },
    "select": {
      "screen":   { "name": "Screen" },
      "currency": { "name": "Currency" }
    },
    "sensor": {
      "current_screen": { "name": "Current screen" },
      "currency":       { "name": "Currency" },
      "nostr_relay":    { "name": "Nostr relay" },
      "rssi":           { "name": "Signal strength" },
      "uptime":         { "name": "Uptime" },
      "free_heap":      { "name": "Free heap" },
      "light_level":    { "name": "Ambient light level" },
      "ota_state":      {
        "name": "OTA state",
        "state": { "idle": "Idle", "updating": "Updating" }
      }
    },
    "switch": {
      "timer":             { "name": "Screen timer" },
      "dnd":               { "name": "Do-not-disturb" },
      "dnd_time_enabled":  { "name": "Scheduled do-not-disturb" },
      "nostr_zap_notify":  { "name": "Nostr Zap notifications" },
      "led_flash_on_zap":  { "name": "LED flash on Nostr Zap" },
      "led_flash_on_update": { "name": "LED flash on new block" },
      "steal_focus":       { "name": "Steal focus on new block" },
      "disable_leds":      { "name": "Disable LEDs" }
    },
    "time": {
      "dnd_start": { "name": "Do-not-disturb start" },
      "dnd_end":   { "name": "Do-not-disturb end" }
    },
    "number": {
      "led_brightness": { "name": "LED brightness" }
    },
    "update": {
      "firmware": { "name": "Firmware" }
    }
  },
  "services": {
    "show_text": {
      "name": "Show text",
      "description": "Display arbitrary text across the BTClock's screens (firmware 3.4.0+).",
      "fields": {
        "device_id": {
          "name": "BTClock",
          "description": "The BTClock device to target."
        },
        "text": {
          "name": "Text",
          "description": "Text to display. Truncated to the device's number of screens; characters are auto-uppercased."
        }
      }
    },
    "show_custom": {
      "name": "Show custom screens",
      "description": "Display one string per screen (firmware 3.4.0+).",
      "fields": {
        "device_id": {
          "name": "BTClock",
          "description": "The BTClock device to target."
        },
        "screens": {
          "name": "Screens",
          "description": "One string per screen. Clamped to the device's number of screens."
        }
      }
    }
  }
}
